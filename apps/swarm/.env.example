# Required
ANTHROPIC_API_KEY=
LINEAR_API_KEY=
GH_TOKEN=

# Agent role: pm | engineer | tester
AGENT_ROLE=engineer

# Repo mappings: label-name=github-org/repo-name (comma-separated)
REPO_MAP=paddock-app=Pontifexx-Tech/paddock-app

# Optional: label filter for polling
POLL_LABEL=agent

# Optional: polling interval
POLL_INTERVAL_MS=120000

# Optional: Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# Optional: custom Linear workflow state names
STATUS_BACKLOG=Backlog
STATUS_IN_PROGRESS=In Progress
STATUS_IN_DEVELOPMENT=In Development
STATUS_IN_REVIEW=In Review
STATUS_DONE=Done
STATUS_WAITING=Waiting
